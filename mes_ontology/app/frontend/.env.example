# AutoML 등 백엔드 연동 (복사 후 .env 로 저장하거나 .env.local 사용)
#
# 권장: Vite dev 서버 프록시(/api → 127.0.0.1:8000). CORS 이슈 없음.
# 백엔드: mes_ontology/app/backend 에서 uvicorn main:app --reload --host 0.0.0.0 --port 8000
VITE_API_URL=/api
#
# 직접 호출 시 (브라우저 Origin이 백엔드 CORS 허용 목록과 일치해야 함)
# VITE_API_URL=http://127.0.0.1:8000
